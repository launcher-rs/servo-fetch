{
  "name": "servo-fetch",
  "version": "0.0.0-development",
  "description": "Fetch, render, and extract web content as Markdown, JSON, or screenshots with an embedded Servo browser engine. No Chromium required.",
  "keywords": [
    "servo",
    "headless-browser",
    "web-scraping",
    "readability",
    "content-extraction",
    "crawler"
  ],
  "homepage": "https://github.com/konippi/servo-fetch",
  "bugs": "https://github.com/konippi/servo-fetch/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konippi/servo-fetch.git",
    "directory": "bindings/node"
  },
  "license": "MIT OR Apache-2.0",
  "author": "konippi",
  "packageManager": "pnpm@11.5.2",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "servo-fetch": "bin/servo-fetch.cjs"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e.test.ts",
    "prepublishOnly": "pnpm run build"
  },
  "optionalDependencies": {
    "@servo-fetch/darwin-arm64": "0.0.0-development",
    "@servo-fetch/darwin-x64": "0.0.0-development",
    "@servo-fetch/linux-arm64-gnu": "0.0.0-development",
    "@servo-fetch/linux-x64-gnu": "0.0.0-development",
    "@servo-fetch/win32-x64-msvc": "0.0.0-development"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.0",
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.0.0",
    "publint": "^0.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
